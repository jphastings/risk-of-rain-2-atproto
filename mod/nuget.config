<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Publicised RoR2/Unity/BepInEx assemblies for CI builds (-p:UseGameLibs=true). -->
    <add key="bepinex" value="https://nuget.bepinex.dev/v3/index.json" />
    <!-- ByJP.AtprotoGaming.Core restores from nuget.org. To test an unreleased core
         build, dotnet pack it into ../packages, bump its version + the PackageReference,
         and add: <add key="local" value="../packages" /> -->
  </packageSources>
</configuration>
